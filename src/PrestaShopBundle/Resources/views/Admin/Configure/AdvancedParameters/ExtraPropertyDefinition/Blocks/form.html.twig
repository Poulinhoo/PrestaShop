{% trans_default_domain 'Admin.Advparameters.Feature' %}

{% form_theme extraPropertyDefinitionForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block extra_property_definition_form %}
  {{ form_start(extraPropertyDefinitionForm) }}
  {{ form_row(extraPropertyDefinitionForm) }}

  <div class="card-footer">
    <a href="{{ path('admin_extra_property_definitions_index') }}" class="btn btn-outline-secondary">
      {{ 'Cancel'|trans({}, 'Admin.Actions') }}
    </a>
    <button class="btn btn-primary float-right" id="save-button">
      {{ 'Save'|trans({}, 'Admin.Actions') }}
    </button>
  </div>

  {{ form_end(extraPropertyDefinitionForm) }}
{% endblock %}
