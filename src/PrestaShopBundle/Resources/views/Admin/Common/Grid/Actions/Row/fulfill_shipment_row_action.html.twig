{% set class = 'btn tooltip-link' %}

{% if attributes.class is defined %}
  {% set class = class ~ ' ' ~ attributes.class %}
{% endif %}

<a href="#"
  class="{{ class }} grid-{{ action.name|lower }}-row-link"
  data-toggle="modal"
  data-target="#fulfillShipmentModal"
  data-show-modal="fulfill-shipment"
  data-shipment-id="{{ record[action.options.shipment_id_field] }}"
  data-order-id="{{ record[action.options.order_id_field] }}"
>
  {% if action.icon is not empty %}
    <i class="material-icons">{{ action.icon }}</i>
  {% endif %}
  {% if not attributes.tooltip_name %}
    {{ action.name }}
  {% endif %}
</a>
